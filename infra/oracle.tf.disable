# Oracle Cloud Always Free ARM VM
# VM.Standard.A1.Flex — Tailscale-only access via egress-only security list

# ---------------------------------------------------------------------------
# Variables
# ---------------------------------------------------------------------------

variable "oracle_ocpus" {
  description = "Number of OCPUs for the Oracle ARM VM (free tier max: 4)"
  type        = number
  default     = 4
}

variable "oracle_memory_in_gbs" {
  description = "Memory in GB for the Oracle ARM VM (free tier max: 24)"
  type        = number
  default     = 24
}

variable "oracle_ad_index" {
  description = "Availability domain index (0-2). Frankfurt has 3 ADs — try different ones if capacity is full."
  type        = number
  default     = 0
}

variable "oracle_boot_volume_size_in_gbs" {
  description = "Boot volume size in GB for the Oracle ARM VM (free tier: 50 GB default, 200 GB max shared)"
  type        = number
  default     = 50
}

# ---------------------------------------------------------------------------
# Data Sources
# ---------------------------------------------------------------------------

data "oci_identity_availability_domains" "ads" {
  compartment_id = var.oci_tenancy_ocid
}

data "oci_core_images" "ubuntu_arm" {
  compartment_id           = var.oci_tenancy_ocid
  operating_system         = "Canonical Ubuntu"
  operating_system_version = "24.04"
  shape                    = "VM.Standard.A1.Flex"
  state                    = "AVAILABLE"
  sort_by                  = "TIMECREATED"
  sort_order               = "DESC"
}

# ---------------------------------------------------------------------------
# Networking
# ---------------------------------------------------------------------------

resource "oci_core_vcn" "main" {
  compartment_id = var.oci_tenancy_ocid
  cidr_blocks    = ["10.0.0.0/16"]
  display_name   = "oracle-${var.oci_region}-vcn"
  dns_label      = "oraclevcn"

  freeform_tags = {
    managed_by = "opentofu"
  }
}

resource "oci_core_internet_gateway" "main" {
  compartment_id = var.oci_tenancy_ocid
  vcn_id         = oci_core_vcn.main.id
  display_name   = "oracle-${var.oci_region}-igw"
  enabled        = true

  freeform_tags = {
    managed_by = "opentofu"
  }
}

resource "oci_core_route_table" "main" {
  compartment_id = var.oci_tenancy_ocid
  vcn_id         = oci_core_vcn.main.id
  display_name   = "oracle-${var.oci_region}-rt"

  freeform_tags = {
    managed_by = "opentofu"
  }

  route_rules {
    destination       = "0.0.0.0/0"
    destination_type  = "CIDR_BLOCK"
    network_entity_id = oci_core_internet_gateway.main.id
  }
}

resource "oci_core_security_list" "egress_only" {
  compartment_id = var.oci_tenancy_ocid
  vcn_id         = oci_core_vcn.main.id
  display_name   = "oracle-${var.oci_region}-sl"

  freeform_tags = {
    managed_by = "opentofu"
  }

  egress_security_rules {
    destination = "0.0.0.0/0"
    protocol    = "all"
    stateless   = false
  }

  # No ingress rules by default — all inbound public traffic is blocked.
  # Tailscale connects outbound via STUN/DERP; no inbound rules needed.
  # Optional SSH ingress for admin IPs (mirrors Hetzner firewall behaviour).
  dynamic "ingress_security_rules" {
    for_each = var.enable_ssh_firewall && length(var.admin_ips) > 0 ? var.admin_ips : []
    content {
      protocol  = "6" # TCP
      source    = ingress_security_rules.value
      stateless = false
      tcp_options {
        min = 22
        max = 22
      }
    }
  }
}

resource "oci_core_subnet" "main" {
  compartment_id             = var.oci_tenancy_ocid
  vcn_id                     = oci_core_vcn.main.id
  cidr_block                 = "10.0.0.0/24"
  display_name               = "oracle-${var.oci_region}-subnet"
  dns_label                  = "oraclesub"
  freeform_tags              = { managed_by = "opentofu" }
  route_table_id             = oci_core_route_table.main.id
  security_list_ids          = [oci_core_security_list.egress_only.id]
  prohibit_public_ip_on_vnic = false
}

# ---------------------------------------------------------------------------
# Cloud-Init
# ---------------------------------------------------------------------------

locals {
  oracle_ssh_public_keys = [for f in fileset(var.ssh_public_key_path, "*.pub") : trimspace(file("${var.ssh_public_key_path}/${f}"))]

  oracle_cloud_init = templatefile("${path.root}/cloud-init/cloud-init.yaml.tftpl", {
    tailscale_auth_key = var.tailscale_auth_key
    username           = var.vm_username
    ssh_public_keys    = local.oracle_ssh_public_keys
    github_token       = var.github_token
    azure_sp_appid     = var.azure_sp_appid
    azure_sp_password  = var.azure_sp_password
    azure_sp_tenant    = var.azure_sp_tenant
    ntfy_channel       = var.ntfy_channel
    bash_aliases       = file("${path.root}/cloud-init/bash_aliases")
  })
}

# ---------------------------------------------------------------------------
# Compute Instance
# ---------------------------------------------------------------------------

resource "oci_core_instance" "arm_vm" {
  compartment_id      = var.oci_tenancy_ocid
  availability_domain = data.oci_identity_availability_domains.ads.availability_domains[var.oracle_ad_index].name
  display_name        = "oracle-${var.oci_region}-arm"
  shape               = "VM.Standard.A1.Flex"

  shape_config {
    ocpus         = var.oracle_ocpus
    memory_in_gbs = var.oracle_memory_in_gbs
  }

  source_details {
    source_type             = "image"
    source_id               = data.oci_core_images.ubuntu_arm.images[0].id
    boot_volume_size_in_gbs = var.oracle_boot_volume_size_in_gbs
  }

  create_vnic_details {
    subnet_id        = oci_core_subnet.main.id
    assign_public_ip = true
    hostname_label   = "oraclearm"
  }

  metadata = {
    ssh_authorized_keys = join("\n", local.oracle_ssh_public_keys)
    user_data           = base64encode(local.oracle_cloud_init)
  }

  preserve_boot_volume = false

  freeform_tags = {
    managed_by = "opentofu"
    location   = var.oci_region
    type       = "VM.Standard.A1.Flex"
  }
}

# ---------------------------------------------------------------------------
# Outputs
# ---------------------------------------------------------------------------

output "oracle_arm_vm_public_ip" {
  description = "Public IP of the Oracle ARM VM (egress only — no inbound access)"
  value       = oci_core_instance.arm_vm.public_ip
}

output "oracle_arm_vm_private_ip" {
  description = "Private IP of the Oracle ARM VM"
  value       = oci_core_instance.arm_vm.private_ip
}

output "oracle_arm_vm_name" {
  description = "Display name of the Oracle ARM VM"
  value       = oci_core_instance.arm_vm.display_name
}

output "oracle_arm_vm_image" {
  description = "Ubuntu ARM image used for the Oracle VM"
  value       = data.oci_core_images.ubuntu_arm.images[0].display_name
}

output "oracle_arm_vm_state" {
  description = "Current state of the Oracle ARM VM"
  value       = oci_core_instance.arm_vm.state
}
